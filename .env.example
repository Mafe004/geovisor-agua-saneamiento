SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Servidor ---
HOST=0.0.0.0
PORT=8000
